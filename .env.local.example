# ─────────────────────────────────────────────────────────────
# 강화유니버스 대시보드 — 환경 변수 예시
#
# 복사해서 .env.local 로 저장 후 실제 값 채우기:
#   cp .env.local.example .env.local
#
# .env.local 은 .gitignore 로 커밋 방지됨.
# Vercel 배포 시에는 프로젝트 Settings → Environment Variables 에 동일한 키로 등록.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Supabase 프로젝트 대시보드 → Settings → API 에서 발급
# NEXT_PUBLIC_ 프리픽스는 브라우저 노출 허용 키에만 사용할 것
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# 서버 전용. RLS 우회 가능한 키이므로 절대 NEXT_PUBLIC_ 으로 노출 금지.
# 관리자 API 라우트 / 시드 스크립트에서만 사용.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── 카카오 OAuth (Supabase Auth Provider) ────────────────────
# 카카오 디벨로퍼스(developers.kakao.com) → 내 애플리케이션 → 앱 키
# Supabase Auth → Providers → Kakao 에도 동일한 값을 등록해야 함
# 리다이렉트 URI: https://<project-ref>.supabase.co/auth/v1/callback
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# ── LLM 편지·요약 보조 (Phase 4~) ───────────────────────────
# 기본 provider 는 Gemini 무료 tier. 사장님이 "첫 문장 제안" 버튼 누를 때만 호출.
# 추후 Anthropic 키 발급 시 LLM_PROVIDER=anthropic 으로 전환 가능.
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
# 기본값: gemini-2.5-flash-lite
GEMINI_MODEL=
ANTHROPIC_API_KEY=
# 기본값: claude-3-5-haiku-latest
ANTHROPIC_MODEL=

# ── 관리자 로그인 (청풍 운영자) ──────────────────────────────
# 환경변수가 아닌 Supabase Auth + app_metadata.role='admin' 로 처리한다.
# 신규 관리자 추가 절차:
#   1) Supabase Dashboard → Authentication → Users → Add user 로 이메일/비밀번호 생성
#   2) SQL Editor 에서 다음 실행 (해당 사용자의 app_metadata 에 role 부여)
#      update auth.users
#         set raw_app_meta_data = raw_app_meta_data || '{"role":"admin"}'::jsonb
#       where email = '<관리자 이메일>';
# 코드는 src/app/admin/login/AdminLoginForm.tsx 가 signInWithPassword 후 role 검증.

# ── 크루 공용 로그인 (Phase 3) ───────────────────────────────
# 크루(강화 현장 운영 자원봉사자) 전원이 공유하는 단일 코드.
# 8자 이상 랜덤. 청풍이 현장에 전달. 노출되면 env 에서 값만 바꿔 재배포 (세션은 만료 시 자동 소멸).
# Phase 7 에서 개별 계정으로 전환 예정.
CREW_ACCESS_CODE=change-me-to-a-crew-shared-code

# ── 앱 자체 설정 ──────────────────────────────────────────────
# 로컬 개발 시 http://localhost:3001, 배포 시 실제 도메인
# (3000 이 다른 프로젝트에서 쓰여서 3001 고정. package.json dev/start 도 동일.)
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ── 개발 전용 임시 로그인 (NODE_ENV !== production 에서만 동작) ──
# 카카오 OAuth 비즈 앱 전환 전까지 쓰는 백도어. 프로덕션 배포에선 자동 비활성화 → Vercel 에 등록 불필요.
# 사용 절차:
#   1) node --env-file=.env.local scripts/bootstrap-dev-user.mjs <email> <password> 로 사용자 준비
#   2) /login 페이지에 "DevLoginButton" 노출 → 클릭으로 즉시 세션 생성
DEV_USER_EMAIL=dev@cheongpung.local
DEV_USER_PASSWORD=change-me-min-8-chars
