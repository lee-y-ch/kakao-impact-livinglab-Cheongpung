# ─────────────────────────────────────────────────────────────
# 강화유니버스 대시보드 — 환경 변수 예시
#
# 복사해서 .env.local 로 저장 후 실제 값 채우기:
#   cp .env.local.example .env.local
#
# .env.local 은 .gitignore 로 커밋 방지됨.
# Vercel 배포 시에는 프로젝트 Settings → Environment Variables 에 동일한 키로 등록.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Supabase 프로젝트 대시보드 → Settings → API 에서 발급
# NEXT_PUBLIC_ 프리픽스는 브라우저 노출 허용 키에만 사용할 것
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# 서버 전용. RLS 우회 가능한 키이므로 절대 NEXT_PUBLIC_ 으로 노출 금지.
# 관리자 API 라우트 / 시드 스크립트에서만 사용.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── 카카오 OAuth (Supabase Auth Provider) ────────────────────
# 카카오 디벨로퍼스(developers.kakao.com) → 내 애플리케이션 → 앱 키
# Supabase Auth → Providers → Kakao 에도 동일한 값을 등록해야 함
# 리다이렉트 URI: https://<project-ref>.supabase.co/auth/v1/callback
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# ── Anthropic (LLM 편지·요약 보조, Phase 4~) ──────────────────
# Haiku 4.5 사용. 사장님이 "첫 문장 제안" 버튼 누를 때만 호출.
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── 관리자 로그인 (청풍 운영자) ──────────────────────────────
# MVP 단계에서는 환경변수 단일 비밀번호. 풀버전에서 Supabase Auth role 로 대체.
ADMIN_PASSWORD=change-me-to-a-long-random-string

# ── 앱 자체 설정 ──────────────────────────────────────────────
# 로컬 개발 시 http://localhost:3000, 배포 시 실제 도메인
NEXT_PUBLIC_SITE_URL=http://localhost:3000
